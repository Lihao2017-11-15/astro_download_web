---
import type { CollectionEntry } from 'astro:content';

interface Props {
  software: CollectionEntry<'software'>;
}

const { software } = Astro.props;
const { title, description, version, category, tags, fileSize, downloadCount, featured, icon } = software.data;
---

<article class="software-card" data-featured={featured}>
  <div class="card-header">
    {icon ? (
      <img src={icon} alt={title} class="software-icon" />
    ) : (
      <div class="icon-placeholder">{title.charAt(0)}</div>
    )}
    <div class="header-info">
      <h3><a href={`/software/${software.slug}`}>{title}</a></h3>
      <span class="category">{category}</span>
    </div>
    {featured && <span class="badge">精选</span>}
  </div>
  
  <p class="description">{description}</p>
  
  <div class="meta">
    <span class="meta-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      {fileSize}
    </span>
    <span class="meta-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2v20M2 12h20"/>
      </svg>
      v{version}
    </span>
    <span class="meta-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      {downloadCount.toLocaleString()} 下载
    </span>
  </div>
  
  <div class="tags">
    {tags.slice(0, 3).map(tag => (
      <span class="tag">{tag}</span>
    ))}
  </div>
  
  <a href={`/software/${software.slug}`} class="details-link">
    查看详情 →
  </a>
</article>

<style>
  .software-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .software-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .software-card[data-featured="true"] {
    border-color: var(--primary);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(59, 130, 246, 0.05) 100%);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .icon-placeholder,
  .software-icon {
    width: 48px;
    height: 48px;
    background: var(--primary);
    color: white;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 600;
    object-fit: cover;
  }

  .header-info {
    flex: 1;
  }

  .header-info h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .header-info h3 a {
    color: var(--text);
    text-decoration: none;
  }

  .header-info h3 a:hover {
    color: var(--primary);
  }

  .category {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--background);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }

  .badge {
    background: var(--primary);
    color: white;
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    text-transform: uppercase;
  }

  .description {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--primary);
    background: rgba(59, 130, 246, 0.1);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }

  .details-link {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
  }

  .details-link:hover {
    text-decoration: none;
  }
</style>
