---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const software = await getCollection('software');
  return software.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, version, category, tags, downloadUrl, fileSize, publishDate, updateDate, author, downloadCount, icon, screenshots } = entry.data;
---

<Layout title={title} description={description}>
  <Header />
  <main>
    <div class="container">
      <div class="breadcrumb">
        <a href="/">首页</a>
        <span>/</span>
        <a href={`/category/${category}`}>{category}</a>
        <span>/</span>
        <span>{title}</span>
      </div>

      <article class="software-detail">
        <header class="detail-header">
          {icon ? (
            <img src={icon} alt={title} class="software-icon" />
          ) : (
            <div class="icon-placeholder large">{title.charAt(0)}</div>
          )}
          <div class="header-content">
            <h1>{title}</h1>
            <p class="description">{description}</p>
            <div class="meta-row">
              <span class="meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
                {author}
              </span>
              <span class="meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                更新于 {updateDate.toLocaleDateString('zh-CN')}
              </span>
              <span class="meta-item">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                {downloadCount.toLocaleString()} 次下载
              </span>
            </div>
          </div>
        </header>

        <div class="detail-grid">
          <div class="main-content">
            <div class="content-card">
              <Content />
            </div>
          </div>

          <aside class="sidebar">
            <div class="sidebar-card">
              <h3>下载信息</h3>
              <div class="info-list">
                <div class="info-item">
                  <span class="info-label">版本</span>
                  <span class="info-value">{version}</span>
                </div>
                <div class="info-item">
                  <span class="info-label">文件大小</span>
                  <span class="info-value">{fileSize}</span>
                </div>
                <div class="info-item">
                  <span class="info-label">分类</span>
                  <span class="info-value">{category}</span>
                </div>
                <div class="info-item">
                  <span class="info-label">发布日期</span>
                  <span class="info-value">{publishDate.toLocaleDateString('zh-CN')}</span>
                </div>
              </div>
              <a href={downloadUrl} target="_blank" rel="noopener noreferrer" class="download-button">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                  <polyline points="7 10 12 15 17 10"/>
                  <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                立即下载
              </a>
            </div>

            <div class="sidebar-card">
              <h3>标签</h3>
              <div class="tags">
                {tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </div>

            {screenshots && screenshots.length > 0 && (
              <div class="sidebar-card">
                <h3>软件截图</h3>
                <div class="screenshots">
                  {screenshots.map((screenshot, index) => (
                    <a href={screenshot} target="_blank" rel="noopener noreferrer" class="screenshot-link">
                      <img src={screenshot} alt={`${title} 截图 ${index + 1}`} class="screenshot-thumb" loading="lazy" />
                    </a>
                  ))}
                </div>
              </div>
            )}
          </aside>
        </div>
      </article>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 0;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--primary);
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .software-detail {
    padding-bottom: 3rem;
  }

  .detail-header {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding: 2rem;
    background: var(--surface);
    border-radius: 1rem;
    border: 1px solid var(--border);
  }

  .icon-placeholder.large,
  .software-icon {
    width: 80px;
    height: 80px;
    font-size: 2rem;
    flex-shrink: 0;
    border-radius: 1rem;
    object-fit: cover;
  }

  .header-content {
    flex: 1;
  }

  .header-content h1 {
    font-size: 1.875rem;
    margin-bottom: 0.5rem;
  }

  .header-content .description {
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
  }

  .content-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 2rem;
  }

  .content-card :global(h2) {
    font-size: 1.5rem;
    margin: 1.5rem 0 1rem;
    color: var(--text);
  }

  .content-card :global(h2:first-child) {
    margin-top: 0;
  }

  .content-card :global(p) {
    line-height: 1.7;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .content-card :global(ul) {
    margin-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .content-card :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1.5rem;
  }

  .sidebar-card h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .info-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .info-item {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
  }

  .info-label {
    color: var(--text-muted);
  }

  .info-value {
    color: var(--text);
    font-weight: 500;
  }

  .download-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.875rem;
    background: var(--primary);
    color: white;
    font-weight: 600;
    border-radius: 0.5rem;
    transition: background 0.2s;
    text-decoration: none;
  }

  .download-button:hover {
    background: var(--primary-dark);
    text-decoration: none;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--primary);
    background: rgba(59, 130, 246, 0.1);
    padding: 0.375rem 0.75rem;
    border-radius: 0.25rem;
  }

  .screenshots {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .screenshot-link {
    display: block;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .screenshot-link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  .screenshot-thumb {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .detail-header {
      flex-direction: column;
      text-align: center;
    }

    .meta-row {
      justify-content: center;
    }

    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
