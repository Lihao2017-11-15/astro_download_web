---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import SoftwareCard from '../components/SoftwareCard.astro';
import { getCollection } from 'astro:content';

const allSoftware = await getCollection('software');
const featuredSoftware = allSoftware.filter(s => s.data.featured);

// 按更新日期排序
const sortedSoftware = allSoftware
  .sort((a, b) => b.data.updateDate.valueOf() - a.data.updateDate.valueOf());

// 按分类获取软件
const getSoftwareByCategory = (category: string) => {
  return allSoftware
    .filter(s => s.data.category === category)
    .slice(0, 4);
};

// 统计每个分类的软件数量并按数量降序排序
const categoryCounts = new Map<string, number>();
allSoftware.forEach(software => {
  const category = software.data.category || '其他';
  categoryCounts.set(category, (categoryCounts.get(category) || 0) + 1);
});

// 转换为数组并排序
const sortedCategories = Array.from(categoryCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6) // 取前6个热门分类
  .map(([name, count]) => ({
    name,
    desc: `${name}相关的Mac软件`,
    count
  }));

// 热门分类
type Category = {
  name: string;
  desc: string;
  count: number;
};

const popularCategories: Category[] = sortedCategories;

// 将软件数据序列化为 JSON，供客户端使用
const softwareData = sortedSoftware.map(software => ({
  slug: software.slug,
  data: {
    title: software.data.title || '未知',
    category: software.data.category || '其他',
    description: software.data.description || '暂无描述',
    version: software.data.version || '未知',
    tags: software.data.tags || [],
    featured: software.data.featured || false
  }
}));
---

<Layout 
  title="首页" 
  description="Mac优质软件下载站，提供免费、安全、纯净的苹果电脑软件，包括工具、开发、媒体、办公等各类Mac软件下载"
  keywords="Mac软件,苹果电脑软件,免费Mac软件,Mac下载,Mac工具,Mac开发,Mac办公,Mac设计"
>
  <Header />
  <main>
    <Hero />
    
    <section class="container section">
      <h2 class="section-title">精选Mac软件</h2>
      <CategoryFilter />
      
      <div id="software-container" class="software-grid"></div>
      
      <!-- 分页 -->
      <div id="pagination" class="pagination" style="display: none;"></div>
    </section>

    <!-- 分类推荐 -->
    <section class="container section categories-section">
      <h2 class="section-title">热门分类</h2>
      <div class="categories-grid">
        {popularCategories.map(category => {
          const categorySoftware = getSoftwareByCategory(category.name);
          return (
            <div key={category.name} class="category-card">
              <a href={`/category/${category.name}`} class="category-header">
                <h3>{category.name}</h3>
                <span class="category-desc">{category.desc}</span>
                <span class="category-count">{category.count} 款软件</span>
              </a>
              <div class="category-software">
                {categorySoftware.map(software => (
                  <a key={software.slug} href={`/software/${software.slug}`} class="category-software-item">
                    <span class="software-name">{software.data.title}</span>
                    <span class="software-version">v{software.data.version}</span>
                  </a>
                ))}
                <a href={`/category/${category.name}`} class="category-more">
                  查看更多 →
                </a>
              </div>
            </div>
          );
        })} 
      </div>
    </section>

    <section class="container section stats-section">
      <div class="stats-grid">
        <div class="stat-item">
          <div class="stat-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 7h-4V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v3H4a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
              <polyline points="16 17 12 13 8 17"/>
            </svg>
          </div>
          <span class="stat-number">{allSoftware.length}+</span>
          <span class="stat-label">Mac软件收录</span>
        </div>
        <div class="stat-item">
          <div class="stat-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <span class="stat-number">100%</span>
          <span class="stat-label">免费安全</span>
        </div>
        <div class="stat-item">
          <div class="stat-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
          </div>
          <span class="stat-number">{new Set(allSoftware.map(s => s.data.category)).size}</span>
          <span class="stat-label">分类覆盖</span>
        </div>
      </div>
    </section>

    <!-- SEO内容 -->
    <section class="container section seo-section">
      <div class="seo-content-wrapper">
        <div class="seo-content">
          <h2 class="seo-title">关于我们</h2>
          <p>Mac软件下载站是一个专注于为Mac用户提供优质免费软件的平台，我们精心挑选每一款软件，确保它们都是安全、纯净、无广告的。</p>
          <p>我们收录了各类Mac软件，包括工具、开发、媒体、办公、设计、网络等多个类别，满足Mac用户的各种需求。</p>
          <p>所有软件均经过严格筛选，确保无恶意代码，无捆绑软件，让您的Mac系统保持干净整洁。</p>
          <p>我们定期更新软件库，确保您能获取到最新版本的软件。如果您有任何问题或建议，欢迎联系我们。</p>
        </div>
        <div class="seo-image">
          <svg width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
            <circle cx="8" cy="8" r="1"/>
            <circle cx="16" cy="8" r="1"/>
          </svg>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script define:vars={{ softwareData }}>
  // 获取 DOM 元素
  const softwareContainer = document.getElementById('software-container');
  const pagination = document.getElementById('pagination');

  // 分页设置
  const pageSize = 12;
  let currentPage = 1;
  let totalPages = 1;

  // 获取当前页码
  function getCurrentPage() {
    const params = new URLSearchParams(window.location.search);
    return Math.max(1, parseInt(params.get('page') || '1'));
  }

  // 显示软件列表
  function displaySoftware() {
    currentPage = getCurrentPage();
    totalPages = Math.ceil(softwareData.length / pageSize);

    // 分页显示结果
    const startIndex = (currentPage - 1) * pageSize;
    const endIndex = startIndex + pageSize;
    const paginatedSoftware = softwareData.slice(startIndex, endIndex);

    softwareContainer.innerHTML = paginatedSoftware.map(software => `
      <article class="software-card" data-featured="${software.data.featured}">
        <div class="card-header">
          <div class="header-info">
            <h3><a href="/software/${software.slug}">${software.data.title}</a></h3>
            <span class="category">${software.data.category}</span>
          </div>
          ${software.data.featured ? '<span class="badge">精选</span>' : ''}
        </div>
        <p class="description">${software.data.description}</p>
        <div class="meta">
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M2 12h20"/>
            </svg>
            v${software.data.version}
          </span>
        </div>
        <div class="tags">
          ${software.data.tags.slice(0, 3).map(tag => `<span class="tag">${tag}</span>`).join('')}
        </div>
        <a href="/software/${software.slug}" class="details-link">查看详情 →</a>
      </article>
    `).join('');

    // 显示分页
    if (totalPages > 1) {
      renderPagination();
    } else {
      pagination.style.display = 'none';
    }
  }

  // 渲染分页
  function renderPagination() {
    pagination.style.display = 'flex';

    const showPages = 5;
    const half = Math.floor(showPages / 2);
    let start = Math.max(1, currentPage - half);
    let end = Math.min(totalPages, start + showPages - 1);

    if (end - start + 1 < showPages) {
      start = Math.max(1, end - showPages + 1);
    }

    let paginationHTML = '';

    // 上一页
    if (currentPage > 1) {
      const prevPage = currentPage - 1;
      const prevUrl = updateUrlParam('page', prevPage);
      paginationHTML += `<a href="${prevUrl}" class="pagination-btn pagination-prev">← 上一页</a>`;
    }

    // 页码
    paginationHTML += '<div class="pagination-numbers">';
    for (let i = start; i <= end; i++) {
      const pageUrl = updateUrlParam('page', i);
      paginationHTML += `<a href="${pageUrl}" class="pagination-number ${i === currentPage ? 'active' : ''}">${i}</a>`;
    }
    paginationHTML += '</div>';

    // 下一页
    if (currentPage < totalPages) {
      const nextPage = currentPage + 1;
      const nextUrl = updateUrlParam('page', nextPage);
      paginationHTML += `<a href="${nextUrl}" class="pagination-btn pagination-next">下一页 →</a>`;
    }

    pagination.innerHTML = paginationHTML;
  }

  // 更新URL参数
  function updateUrlParam(key, value) {
    const params = new URLSearchParams(window.location.search);
    params.set(key, value);
    return `${window.location.pathname}?${params.toString()}`;
  }

  // 页面加载时显示软件列表
  displaySoftware();
</script>