---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const software = await getCollection('software');
  const categories = [...new Set(software.map(s => s.data.category))];
  
  return categories.map(category => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const allSoftware = await getCollection('software');
const categorySoftware = allSoftware.filter(s => s.data.category === category);

// 按更新日期排序
const sortedSoftware = categorySoftware
  .sort((a, b) => b.data.updateDate.valueOf() - a.data.updateDate.valueOf());

// 分类描述映射
const categoryDescriptions = {
  '工具': 'Mac实用工具软件，提升Mac使用效率',
  '媒体': 'Mac媒体播放与编辑软件，享受高品质多媒体体验',
  '设计': 'Mac设计创意软件，释放你的创意潜能',
  '开发': 'Mac开发工具软件，为开发者打造的专业环境',
  '办公': 'Mac办公效率软件，提高工作生产力',
  '网络': 'Mac网络工具软件，安全高效地上网',
  '系统': 'Mac系统工具软件，优化系统性能',
  '娱乐': 'Mac娱乐软件，休闲放松的好帮手',
  '壁纸': 'Mac壁纸软件，美化你的桌面',
  '手机管理': 'Mac手机管理软件，轻松管理移动设备',
  '下载': 'Mac下载工具软件，高速稳定下载',
  '阅读': 'Mac阅读软件，享受阅读的乐趣',
  '图片': 'Mac图片处理软件，美化你的照片',
  '其他': '其他实用的Mac软件'
};

const categoryDescription = (categoryDescriptions as Record<string, string>)[category] || 'Mac软件分类';

// 将软件数据序列化为 JSON，供客户端使用
const softwareData = sortedSoftware.map(software => ({
  slug: software.slug,
  data: {
    title: software.data.title || '未知',
    category: software.data.category || '其他',
    description: software.data.description || '暂无描述',
    version: software.data.version || '未知',
    tags: software.data.tags || [],
    featured: software.data.featured || false
  }
}));
---

<Layout 
  title={`${category} - Mac软件分类`} 
  description={`Mac${category}软件分类，${categoryDescription}，全部免费安全`}
  keywords={`Mac${category},${category}软件,Mac软件下载,免费Mac软件,苹果电脑${category}软件`}
>
  <Header />
  <main>
    <div class="page-header">
      <div class="container">
        <h1>Mac{category}</h1>
        <p>共收录 {categorySoftware.length} 款{category}软件</p>
        <p class="category-description">{categoryDescription}</p>
      </div>
    </div>

    <section class="container section">
      <CategoryFilter activeCategory={category} />
      
      <div id="software-container" class="software-grid"></div>
      
      <!-- 分页 -->
      <div id="pagination" class="pagination" style="display: none;"></div>
    </section>

    <!-- SEO内容 -->
    <section class="container section seo-section">
      <div class="seo-content">
        <h3>关于Mac{category}软件</h3>
        <p>Mac{category}软件是专门为苹果电脑用户设计的{category}相关软件，它们充分利用了Mac系统的优势，提供了更好的用户体验。</p>
        <p>我们收录的{category}软件全部免费，经过严格筛选，确保安全、纯净、无广告，让您的Mac系统保持最佳状态。</p>
        <p>无论您是需要提高工作效率的办公软件，还是追求创意表达的设计软件，或是享受多媒体娱乐的媒体软件，我们都能满足您的需求。</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script define:vars={{ softwareData, category }}>
  // 获取 DOM 元素
  const softwareContainer = document.getElementById('software-container');
  const pagination = document.getElementById('pagination');

  // 分页设置
  const pageSize = 12;
  let currentPage = 1;
  let totalPages = 1;

  // 获取当前页码
  function getCurrentPage() {
    const params = new URLSearchParams(window.location.search);
    return Math.max(1, parseInt(params.get('page') || '1'));
  }

  // 显示软件列表
  function displaySoftware() {
    currentPage = getCurrentPage();
    totalPages = Math.ceil(softwareData.length / pageSize);

    // 分页显示结果
    const startIndex = (currentPage - 1) * pageSize;
    const endIndex = startIndex + pageSize;
    const paginatedSoftware = softwareData.slice(startIndex, endIndex);

    softwareContainer.innerHTML = paginatedSoftware.map(software => `
      <article class="software-card" data-featured="${software.data.featured}">
        <div class="card-header">
          <div class="header-info">
            <h3><a href="/software/${software.slug}">${software.data.title}</a></h3>
            <span class="category">${software.data.category}</span>
          </div>
          ${software.data.featured ? '<span class="badge">精选</span>' : ''}
        </div>
        <p class="description">${software.data.description}</p>
        <div class="meta">
          <span class="meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2v20M2 12h20"/>
            </svg>
            v${software.data.version}
          </span>
        </div>
        <div class="tags">
          ${software.data.tags.slice(0, 3).map(tag => `<span class="tag">${tag}</span>`).join('')}
        </div>
        <a href="/software/${software.slug}" class="details-link">查看详情 →</a>
      </article>
    `).join('');

    // 显示分页
    if (totalPages > 1) {
      renderPagination();
    } else {
      pagination.style.display = 'none';
    }
  }

  // 渲染分页
  function renderPagination() {
    pagination.style.display = 'flex';

    const showPages = 5;
    const half = Math.floor(showPages / 2);
    let start = Math.max(1, currentPage - half);
    let end = Math.min(totalPages, start + showPages - 1);

    if (end - start + 1 < showPages) {
      start = Math.max(1, end - showPages + 1);
    }

    let paginationHTML = '';

    // 上一页
    if (currentPage > 1) {
      const prevPage = currentPage - 1;
      const prevUrl = updateUrlParam('page', prevPage);
      paginationHTML += `<a href="${prevUrl}" class="pagination-btn pagination-prev">← 上一页</a>`;
    }

    // 页码
    paginationHTML += '<div class="pagination-numbers">';
    for (let i = start; i <= end; i++) {
      const pageUrl = updateUrlParam('page', i);
      paginationHTML += `<a href="${pageUrl}" class="pagination-number ${i === currentPage ? 'active' : ''}">${i}</a>`;
    }
    paginationHTML += '</div>';

    // 下一页
    if (currentPage < totalPages) {
      const nextPage = currentPage + 1;
      const nextUrl = updateUrlParam('page', nextPage);
      paginationHTML += `<a href="${nextUrl}" class="pagination-btn pagination-next">下一页 →</a>`;
    }

    pagination.innerHTML = paginationHTML;
  }

  // 更新URL参数
  function updateUrlParam(key, value) {
    const params = new URLSearchParams(window.location.search);
    params.set(key, value);
    return `/category/${category}?${params.toString()}`;
  }

  // 页面加载时显示软件列表
  displaySoftware();
</script>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    opacity: 0.9;
    margin-bottom: 0.5rem;
  }

  .category-description {
    font-size: 0.875rem;
    opacity: 0.8;
  }

  .section {
    padding: 2rem 0 3rem;
  }

  .software-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  /* Software Card Styles */
  .software-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    transition: all 0.3s ease;
  }

  .software-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .software-card[data-featured="true"] {
    border-color: var(--primary);
    background: linear-gradient(135deg, var(--surface) 0%, rgba(59, 130, 246, 0.05) 100%);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .header-info {
    flex: 1;
  }

  .header-info h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
    color: var(--text);
  }

  .header-info h3 a {
    color: var(--text);
    text-decoration: none;
  }

  .header-info h3 a:hover {
    color: var(--primary);
  }

  .category {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--background);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }

  .badge {
    background: var(--primary);
    color: white;
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    text-transform: uppercase;
  }

  .description {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--primary);
    background: rgba(59, 130, 246, 0.1);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }

  .details-link {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
  }

  .details-link:hover {
    text-decoration: none;
  }

  .seo-section {
    background: var(--background);
    border-top: 1px solid var(--border);
  }

  .seo-content {
    max-width: 800px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .seo-content h3 {
    margin-bottom: 1rem;
    color: var(--text);
  }

  .seo-content p {
    margin-bottom: 1rem;
    color: var(--text);
  }

  /* Pagination Styles */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding: 1rem 0;
  }
  
  .pagination-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .pagination-btn:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }
  
  .pagination-numbers {
    display: flex;
    gap: 0.25rem;
  }
  
  .pagination-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .pagination-number:hover {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
  }
  
  .pagination-number.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .pagination {
      flex-wrap: wrap;
      gap: 0.25rem;
    }
    
    .pagination-btn {
      padding: 0.4rem 0.8rem;
      font-size: 0.875rem;
    }
    
    .pagination-number {
      width: 32px;
      height: 32px;
      font-size: 0.875rem;
    }
  }
</style>
