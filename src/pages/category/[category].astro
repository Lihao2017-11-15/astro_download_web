---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import SoftwareCard from '../../components/SoftwareCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const software = await getCollection('software');
  const categories = [...new Set(software.map(s => s.data.category))];
  
  return categories.map(category => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const allSoftware = await getCollection('software');
const categorySoftware = allSoftware.filter(s => s.data.category === category);
---

<Layout title={`${category} - 软件分类`}>
  <Header />
  <main>
    <div class="page-header">
      <div class="container">
        <h1>{category}</h1>
        <p>共收录 {categorySoftware.length} 款软件</p>
      </div>
    </div>

    <section class="container section">
      <CategoryFilter activeCategory={category} />
      
      <div class="software-grid">
        {categorySoftware.map(software => (
          <SoftwareCard software={software} />
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: white;
    padding: 3rem 1rem;
    text-align: center;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    opacity: 0.9;
  }

  .section {
    padding: 2rem 0 3rem;
  }

  .software-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }
</style>
