---
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const {
  title,
  description = "Mac优质软件下载站，提供免费、安全、纯净的苹果电脑软件下载",
  keywords = "Mac软件,苹果电脑软件,免费Mac软件,Mac下载,Mac工具",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Mac软件下载站" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Mac软件下载站</title>
    <style is:global>
      :root {
        --primary: #3b82f6;
        --primary-dark: #2563eb;
        --secondary: #64748b;
        --background: #f8fafc;
        --surface: #ffffff;
        --text: #1e293b;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1);
        --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          "Helvetica Neue", Arial, sans-serif;
        background: var(--background);
        color: var(--text);
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: var(--primary);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1rem;
      }

      main {
        flex: 1;
      }
      .section {
        padding: 3rem 0;
      }

      .section-title {
        text-align: center;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        color: var(--text);
      }

      .software-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.5rem;
      }

      /* Software Card Styles */
      .software-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        padding: 1.25rem;
        transition: all 0.3s ease;
      }

      .software-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-2px);
      }

      .software-card[data-featured="true"] {
        border-color: var(--primary);
        background: linear-gradient(
          135deg,
          var(--surface) 0%,
          rgba(59, 130, 246, 0.05) 100%
        );
      }

      .card-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }

      .header-info {
        flex: 1;
      }

      .header-info h3 {
        font-size: 1.125rem;
        margin-bottom: 0.25rem;
        color: var(--text);
      }

      .header-info h3 a {
        color: var(--text);
        text-decoration: none;
      }

      .header-info h3 a:hover {
        color: var(--primary);
      }

      .category {
        font-size: 0.75rem;
        color: var(--text-muted);
        background: var(--background);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
      }

      .badge {
        background: var(--primary);
        color: white;
        font-size: 0.625rem;
        font-weight: 600;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        text-transform: uppercase;
      }

      .description {
        color: var(--text-muted);
        font-size: 0.875rem;
        line-height: 1.5;
        margin-bottom: 1rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 0.75rem;
      }

      .meta-item {
        display: flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
      }

      .tag {
        font-size: 0.75rem;
        color: var(--primary);
        background: rgba(59, 130, 246, 0.1);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
      }

      .details-link {
        display: inline-block;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--primary);
      }

      .details-link:hover {
        text-decoration: none;
      }

      .categories-section {
        background: var(--surface);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }

      .categories-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        max-width: 1120px;
        margin: 0 auto;
      }

      .category-card {
        background: var(--background);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        padding: 1.5rem;
        transition: all 0.3s ease;
      }

      .category-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-2px);
      }

      .category-header {
        display: block;
        margin-bottom: 1.25rem;
      }

      .category-header h3 {
        font-size: 1.125rem;
        margin-bottom: 0.25rem;
        color: var(--text);
      }

      .category-header:hover h3 {
        color: var(--primary);
      }

      .category-desc {
        font-size: 0.875rem;
        color: var(--text-muted);
        display: block;
        margin-bottom: 0.5rem;
      }

      .category-count {
        font-size: 0.75rem;
        color: var(--primary);
        background: rgba(59, 130, 246, 0.1);
        padding: 0.25rem 0.75rem;
        border-radius: 1rem;
        display: inline-block;
      }

      .category-software {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .category-software-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem;
        border-radius: 0.5rem;
        transition: background 0.2s;
      }

      .category-software-item:hover {
        background: var(--surface);
      }

      .software-name {
        font-size: 0.875rem;
        color: var(--text);
        font-weight: 500;
      }

      .software-version {
        font-size: 0.75rem;
        color: var(--text-muted);
        background: var(--surface);
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
      }

      .category-more {
        display: inline-block;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--primary);
        margin-top: 0.5rem;
        padding: 0.5rem 0;
        text-align: right;
      }

      .category-more:hover {
        text-decoration: none;
        opacity: 0.8;
      }

      .stats-section {
        background: var(--surface);
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding: 4rem 0;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 2.5rem;
        text-align: center;
      }

      .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
      }

      .stat-icon {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(59, 130, 246, 0.1);
        border-radius: 50%;
        color: var(--primary);
      }

      .stat-number {
        display: block;
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--primary);
      }

      .stat-label {
        color: var(--text-muted);
        font-size: 0.875rem;
        text-align: center;
      }

      .seo-section {
        background: var(--background);
        padding: 4rem 0;
      }

      .seo-content-wrapper {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 3rem;
        align-items: center;
      }

      .seo-title {
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        color: var(--text);
      }

      .seo-content {
        line-height: 1.8;
        color: var(--text);
      }

      .seo-content p {
        margin-bottom: 1.25rem;
      }

      .seo-image {
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.7;
      }

      .seo-image svg {
        color: var(--primary);
      }

      /* Pagination Styles */
      .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 2rem;
        padding: 1rem 0;
      }

      .pagination-btn {
        padding: 0.5rem 1rem;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--surface);
        color: var(--text);
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .pagination-btn:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
      }

      .pagination-numbers {
        display: flex;
        gap: 0.25rem;
      }

      .pagination-number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--surface);
        color: var(--text);
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .pagination-number:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
      }

      .pagination-number.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
        font-weight: 600;
      }

      @media (max-width: 768px) {
        .section {
          padding: 2rem 0;
        }

        .categories-grid {
          grid-template-columns: 1fr;
        }

        .stats-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
        }

        .seo-content-wrapper {
          grid-template-columns: 1fr;
          gap: 2rem;
          text-align: center;
        }

        .stat-icon {
          width: 48px;
          height: 48px;
        }

        .stat-icon svg {
          width: 24px;
          height: 24px;
        }

        .stat-number {
          font-size: 2rem;
        }

        .pagination {
          flex-wrap: wrap;
          gap: 0.25rem;
        }

        .pagination-btn {
          padding: 0.4rem 0.8rem;
          font-size: 0.875rem;
        }

        .pagination-number {
          width: 32px;
          height: 32px;
          font-size: 0.875rem;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
